# ============================================================
# RPA 系统环境变量配置示例
# ============================================================
# 使用方式：
# 1. 复制此文件为 .env 或 .env.production
# 2. 修改对应值后，在启动脚本中 source 此文件
# 3. 或直接在 systemd/Supervisor 配置中设置环境变量
# ============================================================

# ============================================================
# 数据库配置
# ============================================================
export DB_URL="jdbc:mysql://localhost:3306/rpa_system?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8"
export DB_USERNAME="rpa_user"
export DB_PASSWORD="YourStrongDatabasePassword123!"

# ============================================================
# Redis 配置
# ============================================================
export REDIS_HOST="localhost"
export REDIS_PORT="6379"
export REDIS_PASSWORD="YourRedisPassword123!"

# ============================================================
# JWT 配置
# ============================================================
# 生成随机密钥: openssl rand -base64 32
export JWT_SECRET="gH/UcRjFf4bG62ok/HKXJ63ybFDaaBFqO/VCq4qpHSI="

# ============================================================
# 邮件配置
# ============================================================
export MAIL_HOST="smtp.163.com"
export MAIL_PORT="465"
export MAIL_USERNAME="lwxiaoye@163.com"
export MAIL_PASSWORD="your-email-app-password"

# ============================================================
# LLM/AI 配置
# ============================================================
export LLM_PROVIDER="deepseek"
export LLM_API_URL="https://api.deepseek.com/v1/chat/completions"
export LLM_API_KEY="your-deepseek-api-key"
export LLM_MODEL="deepseek-chat"

# DeepSeek 配置
export DEEPSEEK_API_URL="https://api.deepseek.com/v1/chat/completions"
export DEEPSEEK_API_KEY="your-deepseek-api-key"
export DEEPSEEK_MODEL="deepseek-chat"

# 小米 MiMo 配置（备用）
export MIMO_API_URL="https://api.xiaomimimo.com/v1/chat/completions"
export MIMO_API_KEY="your-mimo-api-key"
export MIMO_MODEL="mimo-7b-chat"

# ============================================================
# 通知配置
# ============================================================
export NOTIFICATION_ALERT_RECIPIENTS="admin@yourcompany.com"
export NOTIFICATION_SUBSCRIPTION_RECIPIENTS="admin@yourcompany.com"
export NOTIFICATION_REPORT_URL="https://rpa.yourcompany.com"

# ============================================================
# CORS 配置
# ============================================================
export CORS_ALLOWED_ORIGINS="https://rpa.yourcompany.com"

# ============================================================
# 日志配置
# ============================================================
export LOG_LEVEL_ROOT="INFO"
export LOG_FILE_PATH="/var/log/rpa/rpa.log"

# ============================================================
# 上传配置
# ============================================================
export UPLOAD_PATH="/data/rpa/uploads"
export UPLOAD_MAX_SIZE="10485760"

# ============================================================
# 可选：第三方集成配置
# ============================================================
# 钉钉
export DINGTALK_WEBHOOK=""

# 企业微信
export WECOM_CORP_ID=""
export WECOM_AGENT_ID=""
export WECOM_SECRET=""

# 飞书
export FEISHU_APP_ID=""
export FEISHU_APP_SECRET=""
export FEISHU_WEBHOOK=""
