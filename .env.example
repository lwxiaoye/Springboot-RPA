# ===========================================
# RPA 系统 Docker 环境变量配置
# ===========================================
# 复制此文件为 .env 并填入实际值
# 注意: .env 文件不要提交到 Git！
# ===========================================

# ========== 数据库配置 ==========
DB_PASSWORD=rpa123456
DB_URL=jdbc:mysql://rpa-mysql:3306/rpa?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true

# ========== MySQL 容器配置 ==========
MYSQL_ROOT_PASSWORD=rpa_root_2024
MYSQL_DATABASE=rpa
MYSQL_USER=rpa
MYSQL_PASSWORD=rpa123456

# ========== Redis 配置 ==========
REDIS_PASSWORD=
REDIS_HOST=rpa-redis
REDIS_PORT=6379

# ========== JWT 配置 ==========
# 【重要】生产环境必须设置至少32字节的随机密钥
# 生成方式: openssl rand -base64 32
JWT_SECRET=gH/UcRjFf4bG62ok/HKXJ63ybFDaaBFqO/VCq4qpHSI=

# ========== AI/LLM 配置 ==========
# 主要使用 DeepSeek v4.0 Pro
LLM_PROVIDER=deepseek
LLM_API_KEY=your-deepseek-api-key
LLM_MODEL=deepseek-chat

# DeepSeek 配置
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# 小米 MiMo 配置（备用）
MIMO_API_URL=https://api.xiaomimimo.com/v1/chat/completions
MIMO_API_KEY=your-mimo-api-key
MIMO_MODEL=mimo-7b-chat

# ========== 邮件配置 ==========
MAIL_HOST=smtp.163.com
MAIL_PORT=465
MAIL_USERNAME=lwxiaoye@163.com
MAIL_PASSWORD=your-email-password

# ========== 通知配置 ==========
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-token
WECOM_CORP_ID=your-corp-id
WECOM_AGENT_ID=your-agent-id
WECOM_SECRET=your-secret
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id

# ========== CORS 配置 ==========
# 允许的跨域来源，多个域名用逗号分隔
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80

# ========== 文件上传配置 ==========
UPLOAD_PATH=/app/uploads
UPLOAD_MAX_FILE_SIZE=10485760

# ========== 日志配置 ==========
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_RPA=INFO
