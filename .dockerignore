# ===========================================
# Docker 构建忽略文件
# ===========================================
# 这些文件和目录不会被打包到 Docker 镜像中
# ===========================================

# Git
.git
.gitignore

# IDE
.idea
.vscode
*.iml

# 前端依赖（会在容器内重新安装）
node_modules
npm-debug.log
yarn-error.log

# 构建产物（会在容器内重新构建）
dist
target

# 日志和临时文件
logs
*.log
*.log.*
temp
tmp
*.tmp

# 敏感文件
*.env
!.env.example
*.pem
*.key
credentials.json

# Docker 相关（避免递归）
Dockerfile
Dockerfile.*
docker-compose*
.dockerignore

# 文档
*.md
docs
LICENSE

# 测试文件
*.test.js
*.spec.js
src/test

# 其他
*.bak
*.swp
*.swo
.DS_Store
Thumbs.db
